# Goes in ~/

# Keyboard Layout
setxkbmap us altgr-intl

# Keyboard bindings
xbindkeys

# Turn off bluetooth adapter
rfkill block bluetooth

# If DisplayPort output is detected, make it primary and open xrandr GUI
if xrandr --listmonitors | grep 'DisplayPort'; then
    xrandr --output DisplayPort-1 --primary &
    arandr &
fi
# Ditto for HDMI (note that, if present, it overrides DisplayPort)
if xrandr --listmonitors | grep 'HDMI'; then
    xrandr --output HDMI-1 --primary &
    arandr &
fi

# Wallpaper
nitrogen --restore &

# Compositor
picom -f &

# Synchronize PRIMARY, CLIPBOARD and cut buffer selections
autocutsel -fork &
autocutsel -selection PRIMARY -fork &

# Start up pipewire (leave near end) and set volume to 25/100
/usr/bin/pipewire &
/usr/bin/pipewire-pulse &
/usr/bin/wireplumber &
/usr/bin/pamixer --set-volume 30 &

# Activate numlock
#numlockx on &

# Keyboard Lighting
#ckb-next -b &
